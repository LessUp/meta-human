# MetaHuman 后端服务环境变量配置 (v1.1.0)
# 复制此文件为 .env 并填入实际值
#
# 架构说明（参考 AIRI 模块化设计）:
#   app/config.py       → 配置 schema 验证
#   app/errors.py       → 统一错误体系
#   app/middleware.py    → 请求日志 + 速率限制
#   app/services/        → 业务层 (session / llm / mock / dialogue)
#   app/api/             → 路由层 (chat / health / tts)

# ---- LLM 配置 ----
# OpenAI API Key（未配置时自动降级为智能 Mock 模式）
OPENAI_API_KEY=
# 模型名称（默认: gpt-3.5-turbo）
OPENAI_MODEL=gpt-3.5-turbo
# API 基础地址（支持 OpenAI 兼容的第三方服务，如 DeepSeek / 通义千问）
OPENAI_BASE_URL=https://api.openai.com/v1
# LLM 提供商（当前仅支持 openai）
LLM_PROVIDER=openai
# LLM 请求超时时间（秒，默认: 30）
LLM_TIMEOUT_SECONDS=30

# ---- 会话配置 ----
# 每个会话最大保留消息数（默认: 20）
DIALOGUE_MAX_SESSION_MESSAGES=20
# 会话过期时间（秒，默认: 3600 即 1 小时）
SESSION_TTL_SECONDS=3600

# ---- CORS 配置 ----
# 允许的前端域名，多个用逗号分隔（留空则使用默认 localhost）
CORS_ALLOW_ORIGINS=

# ---- 日志配置 ----
# 日志级别: DEBUG, INFO, WARNING, ERROR（默认: INFO）
LOG_LEVEL=INFO
