# Required for real LLM replies in production
OPENAI_API_KEY=

# LLM provider settings
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER=openai

# Text-to-Speech
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%

# Speech-to-Text
ASR_PROVIDER=whisper
ASR_MODEL=whisper-1
ASR_LANGUAGE=zh

# Dialogue/session controls
DIALOGUE_MAX_HISTORY_LENGTH=20
DIALOGUE_MAX_SESSION_MESSAGES=10
RATE_LIMIT_RPM=60

# CORS: use the GitHub Pages origin, not the full hash route
CORS_ALLOW_ORIGINS=https://lessup.github.io

# Logging
LOG_LEVEL=INFO
