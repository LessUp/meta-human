# MetaHuman 后端服务环境变量配置
# 复制此文件为 .env 并填入实际值

# ---- LLM 配置 ----
# OpenAI API Key（未配置时将使用智能 Mock 回复）
OPENAI_API_KEY=
# 模型名称（默认: gpt-3.5-turbo）
OPENAI_MODEL=gpt-3.5-turbo
# API 基础地址（支持兼容 OpenAI 格式的第三方服务）
OPENAI_BASE_URL=https://api.openai.com/v1
# LLM 提供商（当前仅支持 openai）
LLM_PROVIDER=openai
# LLM 请求超时时间（秒，默认: 30）
LLM_TIMEOUT_SECONDS=30

# ---- 会话配置 ----
# 每个会话最大保留消息数（默认: 20）
DIALOGUE_MAX_SESSION_MESSAGES=20
# 会话过期时间（秒，默认: 3600 即 1 小时）
SESSION_TTL_SECONDS=3600

# ---- CORS 配置 ----
# 允许的前端域名，多个用逗号分隔（留空则使用默认值）
CORS_ALLOW_ORIGINS=

# ---- 日志配置 ----
# 日志级别: DEBUG, INFO, WARNING, ERROR（默认: INFO）
LOG_LEVEL=INFO
