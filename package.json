{
  "name": "metahuman-engine",
  "version": "2.0.0",
  "description": "A modular, real-time 3D digital human interaction engine for the browser.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:pages": "tsc && vite build --mode pages && bash scripts/build-pages.sh",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "build:mobile": "tsc && vite build --mode mobile",
    "build:desktop": "tsc && vite build --mode desktop",
    "build:ar": "tsc && vite build --mode ar",
    "serve": "vite preview --host 0.0.0.0 --port 3000",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "lint:fix": "eslint . --fix --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"*.md\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"*.md\" \"docs/**/*.md\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "build:analyze": "tsc && vite build --mode analyze",
    "preview:https": "vite preview --https"
  },
  "dependencies": {
    "@mediapipe/face_mesh": "^0.4.1633559619",
    "@mediapipe/pose": "^0.5.1675469404",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.177.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.3.1",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.177.0",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lightningcss": "^1.30.1",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "rollup-plugin-visualizer": "^6.0.1",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.5",
    "vite-plugin-compression2": "^2.0.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "digital-human",
    "3d-modeling",
    "webgl",
    "threejs",
    "react",
    "typescript",
    "voice-interaction",
    "ai-avatar",
    "metaverse"
  ],
  "author": "LessUp",
  "license": "MIT",
  "homepage": "https://lessup.github.io/meta-human/",
  "bugs": {
    "url": "https://github.com/LessUp/meta-human/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LessUp/meta-human.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "last 2 versions",
      "not ie 11"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
